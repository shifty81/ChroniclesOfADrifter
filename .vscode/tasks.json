{
  "version": "2.0.0",
  "tasks": [
    // ── C# Game ──────────────────────────────────────────────────────────────
    {
      "label": "build: C# Game (Debug)",
      "type": "shell",
      "command": "dotnet build -c Debug --nologo",
      "options": {
        "cwd": "${workspaceFolder}/src/Game"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "build: C# Game (Release)",
      "type": "shell",
      "command": "dotnet build -c Release --nologo",
      "options": {
        "cwd": "${workspaceFolder}/src/Game"
      },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    // ── Full Solution (C++ engine + C# game) ──────────────────────────────────
    {
      "label": "build: Full Solution (Windows)",
      "type": "shell",
      "command": "build.bat",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "build.bat"
      },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "build: Full Solution (Linux/macOS)",
      "type": "shell",
      "command": "bash build.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    // ── Run helpers (not normally needed — use launch.json instead) ───────────
    {
      "label": "run: DevWorld (Debug)",
      "type": "shell",
      "command": "dotnet run -c Debug -- devworld",
      "options": {
        "cwd": "${workspaceFolder}/src/Game"
      },
      "dependsOn": "build: C# Game (Debug)",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run: Map Editor (Debug)",
      "type": "shell",
      "command": "dotnet run -c Debug -- editor",
      "options": {
        "cwd": "${workspaceFolder}/src/Game"
      },
      "dependsOn": "build: C# Game (Debug)",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run: Complete Game Loop (Debug)",
      "type": "shell",
      "command": "dotnet run -c Debug -- complete",
      "options": {
        "cwd": "${workspaceFolder}/src/Game"
      },
      "dependsOn": "build: C# Game (Debug)",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
